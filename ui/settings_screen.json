{
  "namespace": "settings",

  "screen_controls_and_settings": {
    "$xc_modern_settings": true
  },

  "settings_screen_base": {
    "$xc_modern_settings|default": false,
    "variables": [
      {
        "requires": "($is_realm_slot or $realm_no_world_edit)",
        "$screen_background_control": "realms_slots.realms_background"
      },
      {
        "requires": "$xc_modern_settings",
        "$screen_content": "xc_modern_settings:main_content.main_content",
        "$screen_bg_content": "xc_modern_settings:main_content.background",
        "$screen_animations": [
          "@common.screen_exit_animation_push_fade",
          "@common.screen_exit_animation_pop_fade",
          "@common.screen_entrance_animation_push_fade",
          "@common.screen_entrance_animation_pop_fade"
        ]
      }
    ]
  },

  "screen_world_create": {},
  "screen_template_create": {},
  "screen_world_edit": {},
  "screen_world_controls_and_settings": {},
  "screen_realm_controls_and_settings": {},
  "screen_realm_member_controls_and_settings": {},
  "screen_realm_settings": {},
  "screen_world_slot_edit": {},
  "screen_realm_manage": {},
  "screen_realm_invite_link_settings": {}
}
