{
  "namespace": "xc_modern_settings:controls",

  "option_text_edit_control@xc_modern_edit_box.text_edit_box": {
    "size": ["50% + 100px", 23],
    "$text_edit_box_content_binding_name": "$option_binding_name",
    "$text_edit_box_binding_collection_name": "$option_binding_name",
    "$text_edit_box_binding_type": "global",
    "$text_box_enabled_binding_name": "$option_enabled_binding_name",
    "enabled": "$enabled",
    "$place_holder_text": "$option_place_holder_text",
    "$text_box_tts_header": "$option_label",
    "variables": [
      {
        "requires": "(not $option_enabled_binding_name or not $enabled)",
        "$text_box_enabled_binding_name": "#not_data_bound",
        "$text_edit_box_enabled_binding_type": "none"
      }
    ]
  },

  "option_toggle_state": {
    "type": "image",
    "size": [12, 12],
    "texture": "textures/XeroxClient/rounded_corner/all8x",
    "anchor_from": "left_middle",
    "anchor_to": "left_middle"
  },

  "option_toggle_default@xc_modern_settings:controls.option_toggle_state": {
    "color": "$xeroxclient_ui_theme_button_default_color",
    "alpha": "$xeroxclient_ui_theme_button_default_alpha"
  },

  "option_toggle_unchecked_hover@xc_modern_settings:controls.option_toggle_state": {
    "color": "$xeroxclient_ui_theme_button_default_color",
    "alpha": "$xeroxclient_ui_theme_button_hover_alpha"
  },

  "option_toggle_checked_hover@xc_modern_settings:controls.option_toggle_state": {
    "color": "$xeroxclient_ui_theme_button_hover_color",
    "alpha": "$xeroxclient_ui_theme_button_hover_alpha"
  },

  "option_toggle_pressed@xc_modern_settings:controls.option_toggle_state": {
    "color": "$xeroxclient_ui_theme_button_pressed_color"
    //"alpha": "$xeroxclient_ui_theme_button_pressed_alpha"
  },

  "option_toggle_locked@xc_modern_settings:controls.option_toggle_state": {
    "color": "$xeroxclient_ui_theme_button_locked_color",
    "alpha": "$xeroxclient_ui_theme_button_locked_alpha"
  },

  "option_toggle_control@settings_common.option_toggle_control": {
    "$unchecked_control": "xc_modern_settings:controls.option_toggle_default",
    "$checked_control": "xc_modern_settings:controls.option_toggle_pressed",
    "$unchecked_hover_control": "xc_modern_settings:controls.option_toggle_unchecked_hover",
    "$checked_hover_control": "xc_modern_settings:controls.option_toggle_checked_hover",
    "$unchecked_locked_control": "xc_modern_settings:controls.option_toggle_locked",
    "$unchecked_locked_hover_control": "xc_modern_settings:controls.option_toggle_locked",
    "$checked_locked_control": "xc_modern_settings:controls.option_toggle_locked",
    "$checked_locked_hover_control": "xc_modern_settings:controls.option_toggle_locked"
  },

  "option_radio_state": {
    "type": "panel",
    "size": ["100%", 16],
    "$radio_label_bindings|default": [],
    "$no_label|default": false,
    "controls": [
      {
        "radio_image@$toggle_state": {
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "layer": 2
        }
      },
      {
        "radio_label": {
          "ignored": "$no_label",
          "type": "label",
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "text": "$radio_label_text",
          "font_type": "$global_font_type",
          "backup_font_type": "$global_font_type_backup",
          "offset": [14, 0],
          "size": ["100% - 16px", "default"],
          "bindings": "$radio_label_bindings",
          "layer": 2
        }
      }
    ]
  },

  "option_radio_default@xc_modern_settings:controls.option_radio_state": {
    "$toggle_state": "xc_modern_settings:controls.option_toggle_default"
  },

  "option_radio_unchecked_hover@xc_modern_settings:controls.option_radio_state": {
    "$toggle_state": "xc_modern_settings:controls.option_toggle_unchecked_hover"
  },

  "option_radio_checked_hover@xc_modern_settings:controls.option_radio_state": {
    "$toggle_state": "xc_modern_settings:controls.option_toggle_checked_hover"
  },

  "option_radio_pressed@xc_modern_settings:controls.option_radio_state": {
    "$toggle_state": "xc_modern_settings:controls.option_toggle_pressed"
  },

  "option_radio_locked@xc_modern_settings:controls.option_radio_state": {
    "$toggle_state": "xc_modern_settings:controls.option_toggle_locked"
  },

  "radio_with_label_core@settings_common.radio_with_label_core": {
    "$unchecked_control": "xc_modern_settings:controls.option_radio_default",
    "$checked_control": "xc_modern_settings:controls.option_radio_pressed",
    "$unchecked_hover_control": "xc_modern_settings:controls.option_radio_unchecked_hover",
    "$checked_hover_control": "xc_modern_settings:controls.option_radio_checked_hover",
    "$unchecked_locked_control": "xc_modern_settings:controls.option_radio_locked",
    "$unchecked_locked_hover_control": "xc_modern_settings:controls.option_radio_locked",
    "$checked_locked_control": "xc_modern_settings:controls.option_radio_locked",
    "$checked_locked_hover_control": "xc_modern_settings:controls.option_radio_locked"
  },

  "radio_with_label": {
    "type": "panel",
    "size": ["100%", 16],
    "$enabled|default": true,
    "controls": [
      {
        "radio_with_label_core@xc_modern_settings:controls.radio_with_label_core": {}
      }
    ]
  },

  "option_radio_dropdown_group@settings_common.option_radio_group_control": {},

  "option_slider_control": {
    "type": "panel",
    "size": ["50%", 16],
    "controls": [
      {
        "slider@xc_modern_slider.slider": {
          "$option_label|default": "",
          "$slider_tts_header": "$option_label",
          "$slider_tts_header_binding_type": "global",
          "enabled": "$enabled",
          "$slider_enabled_binding_name": "$option_enabled_binding_name",
          "$slider_enabled_binding_type": "global",
          "variables": [
            {
              "requires": "(not $option_enabled_binding_name or not $enabled)",
              "$slider_enabled_binding_name": "#not_data_bound",
              "$slider_enabled_binding_type": "none"
            }
          ]
        }
      }
    ]
  },

  "dropdown@common.dropdown": {
    "$use_scrolling_panel|default": false, // if options more than 4, then enable it.
    "$dropdown_content_controls": [
      {
        "background": {
          "type": "image",
          "size": ["100%", "100%c + 2px"],
          "alpha": "$xeroxclient_ui_theme_menu_background_alpha",
          "texture": "textures/XeroxClient/rounded_corner/all8x",
          "color": "$xeroxclient_ui_theme_menu_background_color",
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "controls": [
            {
              "dropdown_content@$dropdown_content": {
                "size": ["100% - 4px", "100%c"]
              }
            }
          ]
        }
      }
    ],
    "variables": [
      {
        "requires": "$use_scrolling_panel",
        "$dropdown_content_controls": [
          {
            "background": {
              "type": "image",
              "size": ["100%", 66],
              "alpha": "$xeroxclient_ui_theme_menu_background_alpha",
              "texture": "textures/XeroxClient/rounded_corner/all8x",
              "color": "$xeroxclient_ui_theme_menu_background_color",
              "anchor_from": "top_left",
              "anchor_to": "top_left",
              "controls": [
                {
                  "scroll@xc_modern_scrolling_panel.scrolling_panel": {
                    "size": ["100% - 4px", "100% - 2px"],
                    "$scrolling_content": "$dropdown_content",
                    "layer": 4
                  }
                }
              ]
            }
          }
        ]
      }
    ]
  },

  "dropdown_label": {
    "type": "label",
    "layer": 3,
    "$options_dropdown_label_color_binding_type|default": "none",
    "$options_dropdown_label_color_binding|default": "",
    "$options_dropdown_toggle_label_font_scale|default": 1.0,
    "size": ["default", "default"],
    "max_size": ["100%", "default"],
    "text": "$options_dropdown_toggle_label_binding",
    "font_type": "$global_font_type",
    "backup_font_type": "$global_font_type_backup",
    "font_scale_factor": "$options_dropdown_toggle_label_font_scale",
    "alpha": "$content_alpha",
    "$tts_override_control_value|default": "$options_dropdown_toggle_label_binding",
    "tts_override_control_value": "$tts_override_control_value",
    "$options_dropdown_toggle_label_binding_type|default": "global",
    "$options_dropdown_toggle_label_binding_collection_name|default": "",
    "$options_dropdown_label_bindings|default": [
      {
        "binding_name": "$options_dropdown_toggle_label_binding",
        "binding_condition": "none",
        "binding_type": "$options_dropdown_toggle_label_binding_type",
        "binding_collection_name": "$options_dropdown_toggle_label_binding_collection_name"
      },
      {
        "binding_name": "$options_dropdown_label_color_binding",
        "binding_type": "$options_dropdown_label_color_binding_type",
        "binding_name_override": "#color"
      },
      {
        "binding_name": "$tts_override_control_value",
        "binding_condition": "none",
        "binding_type": "$options_dropdown_toggle_label_binding_type",
        "binding_collection_name": "$options_dropdown_toggle_label_binding_collection_name"
      }
    ],
    "bindings": "$options_dropdown_label_bindings"
  },

  "options_dropdown_toggle_control@common_toggles.light_template_toggle": {
    "size": ["100%", "100%"],
    "$xeroxclient_ui_control": true,
    "$button_type_panel": "xc_modern_settings:controls.dropdown_label",
    "enabled": "$enabled",
    "$toggle_enabled_binding_name|default": "$option_enabled_binding_name",
    "$toggle_enabled_binding_type|default": "global",
    "$toggle_binding_type|default": "global",
    "variables": [
      {
        "requires": "(not $option_enabled_binding_name or not $enabled)",
        "$toggle_enabled_binding_name": "#not_data_bound",
        "$toggle_enabled_binding_type": "none"
      }
    ],
    "$default_texture": "textures/XeroxClient/rounded_corner/all8x",
    "$hover_texture": "textures/XeroxClient/rounded_corner/all8x",
    "$pressed_texture": "textures/XeroxClient/rounded_corner/all8x",
    "$pressed_no_hover_texture": "textures/XeroxClient/rounded_corner/all8x",
    "$locked_texture": "textures/XeroxClient/rounded_corner/all8x"
  },

  "option_dropdown_control": {
    "type": "panel",
    "size": [100, 20],
    "$option_dropdown_type|default": "xc_modern_settings:controls.dropdown",
    "layer": 2,
    "controls": [
      {
        "dropdown@$option_dropdown_type": {
          "$dropdown_toggle": "xc_modern_settings:controls.options_dropdown_toggle_control",
          "$dropdown_content|default": "unset $dropdown_content",
          "$dropdown_name|default": "unset $dropdown_name",
          "$options_dropdown_toggle_label_binding|default": "unset $options_dropdown_toggle_label_text",
          "$locked_alpha": 0.5,
          "$toggle_tts_header": "$option_label"
        }
      }
    ]
  },

  "option_generic": {
    "type": "panel",
    "$option_generic_panel_size|default": ["100%", "100%c"],
    "size": "$option_generic_panel_size",
    "$enabled|default": true,
    "$option_enabled_binding_name|default": "",
    "controls": [
      {
        "option_generic_core@xc_modern_settings:controls.option_generic_core": {}
      }
    ]
  },

  "option_generic_core": {
    "$option_label|default": "",
    "$show_option_label|default": true,
    "$has_option_description|default": false,
    "$option_description|default": "",
    "$option_enabled_binding_type|default": "global",
    "type": "stack_panel",
    "size": ["100% - 2px", "100%c"],
    "enabled": "$enabled",
    "variables": [
      {
        "requires": "(not $enabled or not $option_enabled_binding_name)",
        "$option_enabled_binding_type": "none",
        "$option_enabled_binding_name": "#not_data_bound"
      }
    ],
    "bindings": [
      {
        "binding_type": "$option_enabled_binding_type",
        "binding_name": "$option_enabled_binding_name",
        "binding_name_override": "#enabled"
      }
    ],
    "controls": [
      {
        "layout": {
          "type": "panel",
          "$option_size|default": ["100%", "100%cm + 2px"],
          "size": "$option_size",
          "$label_size|default": ["50%", "default"],
          "$label_offset|default": [0, 0],
          "$label_bindings|default": [],
          "$control_anchor|default": "right_middle",
          "controls": [
            {
              "$control_name@$control_name": {
                "anchor_from": "$control_anchor",
                "anchor_to": "$control_anchor"
              }
            },
            {
              "option_label": {
                "type": "label",
                "layer": 9,
                "size": "$label_size",
                "offset": "$label_offset",
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "text": "$option_label",
                "font_type": "$global_font_type",
                "backup_font_type": "$global_font_type_backup",
                "visible": "$show_option_label",
                "bindings": "$label_bindings",
                "locked_color": "$xeroxclient_ui_theme_button_text_locked_color"
              }
            }
          ]
        }
      },
      {
        "description_text_panel": {
          "type": "panel",
          "size": ["100%", "100%c + 2px"],
          "ignored": "(not $has_option_description)",
          "visible": "$show_option_label",
          "controls": [
            {
              "option_descriptive_text": {
                "type": "label",
                "size": "$description_size",
                "$description_size|default": ["50% - 10px", "default"],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "color": "$xeroxclient_ui_theme_secondary_text_color",
                "text": "$option_description",
                "font_type": "$global_font_type",
                "backup_font_type": "$global_font_type_backup",
                "font_scale_factor": 0.75
              }
            }
          ]
        }
      }
    ]
  },

  "option_toggle@xc_modern_settings:controls.option_generic": {
    "$control_anchor": "left_middle",
    "$label_size": ["100% - 14px", "default"],
    "$label_offset": [14, 0],
    "$description_size": ["100% - 10px", "default"],
    "$control_name": "xc_modern_settings:controls.option_toggle_control"
  },

  "option_text_edit@xc_modern_settings:controls.option_generic": {
    "$label_size": ["50% - 100px", "default"],
    "$option_place_holder_text|default": "...",
    "$control_name": "xc_modern_settings:controls.option_text_edit_control"
  },

  "option_slider@xc_modern_settings:controls.option_generic": {
    "$control_name": "xc_modern_settings:controls.option_slider_control"
  },

  "option_dropdown@xc_modern_settings:controls.option_generic": {
    "$label_size": ["100% - 100px", "default"],
    "$control_name": "xc_modern_settings:controls.option_dropdown_control"
  }
}
