{
  "namespace": "xc_modern_settings:main_content",
  "toggle_button_control": {
    "type": "panel",
    "layer": 2,
    "size": ["100%", 20],
    "$button_icon|default": "none",
    "controls": [
      {
        "glyph": {
          "type": "image",
          "texture": "('textures/XeroxClient/icon/' + $button_icon)",
          "size": [15, 15],
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "layer": 3
        }
      },
      {
        "button_text": {
          "type": "label",
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "offset": [20, 0],
          "size": ["default", "default"],
          "max_size": ["100% - 20px", "100%"],
          "text": "$button_text",
          "layer": 3,
          "font_type": "$global_font_type",
          "backup_font_type": "$global_font_type_backup",
          "$button_text_binding_type|default": "none",
          "$button_text_grid_collection_name|default": "",
          "$button_text_binding_condition|default": "none",
          "bindings": [
            {
              "binding_type": "$button_text_binding_type",
              "binding_condition": "$button_text_binding_condition",
              "binding_collection_name": "$button_text_grid_collection_name",
              "binding_name": "$button_text",
              "binding_name_override": "$button_text"
            }
          ]
        }
      }
    ]
  },
  "section_toggle_base@common_toggles.a_rc_8x_image": {
    "size": ["100%", 25],
    "$button_content": "xc_modern_settings:main_content.toggle_button_control",
    "$radio_toggle_group": true,
    "$toggle_name": "navigation_tab",
    "$toggle_group_default_selected": "$default_selector_toggle_index",
    "$toggle_tab_focus_binding_type": "global",
    "$toggle_tab_focus_binding_name": "#navigation_tab_focus_precedence",
    "$toggle_on_hover_binding_type": "global",
    "$toggle_on_hover_binding_name": "#toggle_on_hover"
  },
  "selector_group_label": {
    "type": "image",
    "texture": "textures/XeroxClient/rounded_corner/all8x",
    "color": "$xeroxclient_ui_theme_menu_background_color",
    "alpha": "$xeroxclient_ui_theme_menu_background_alpha",
    "size": ["100%", 17],
    "controls": [
      {
        "text": {
          "type": "label",
          "text": "$section_text",
          "font_type": "$global_font_type",
          "backup_font_type": "$global_font_type_backup",
          "size": ["100%", "default"],
          "text_alignment": "center"
        }
      }
    ]
  },
  "section_selector_panel": {
    "type": "stack_panel",
    "size": ["100%", "100%c"],
    "$default_selector_toggle_index": 101,
    "controls": [
      {
        "accessibility@xc_modern_settings:main_content.section_toggle_base": {
          "$button_icon": "accessibility",
          "$button_text": "options.accessibility",
          "$toggle_view_binding_name": "accessibility_button_toggle",
          //"$toggle_group_forced_index": "$accessibility_forced_index",
          "$toggle_group_forced_index": 101,
          "ignored": "(not $include_controls_and_settings_sections)"
        }
      },
      {
        "world": {
          "type": "stack_panel",
          "size": ["100%", "100%c"],
          "ignored": "(not $include_world_section)",
          "controls": [
            {
              "world_group_name@xc_modern_settings:main_content.selector_group_label": {
                "$section_text": "realmsSettingsScreen.worldSectionTitle"
              }
            },
            {
              "game@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "world",
                "$button_text": "options.category.game",
                "$toggle_view_binding_name": "game_button_toggle",
                "$toggle_group_forced_index": "$game_forced_index"
              }
            },
            {
              "multiplayer@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "multiplayer",
                "$button_text": "options.group.multiplayer",
                "$toggle_view_binding_name": "multiplayer_button_toggle",
                "$toggle_group_forced_index": "$multiplayer_forced_index"
              }
            }
          ]
        }
      },
      {
        "controls": {
          "type": "stack_panel",
          "size": ["100%", "100%c"],
          "ignored": "(not $include_controls_and_settings_sections)",
          "controls": [
            {
              "controls_group_name@xc_modern_settings:main_content.selector_group_label": {
                "$section_text": "options.group.input"
              }
            },
            {
              "keyboard_and_mouse_button@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "keyboard_and_mouse",
                "$button_text": "options.keyboardAndMouse",
                "$toggle_view_binding_name": "keyboard_and_mouse_button_toggle",
                "ignored": "(not $keyboard_and_mouse_supported)",
                "$toggle_group_forced_index": "$keyboard_and_mouse_forced_index"
              }
            },
            {
              "controller_button@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "controller",
                "$button_text": "options.controller",
                "$toggle_view_binding_name": "controller_button_toggle",
                "ignored": "(not $gamepad_supported or $nx_os)",
                "$toggle_group_forced_index": "$controller_and_switch_forced_index"
              }
            },
            {
              "touch_button@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "touch",
                "$button_text": "options.touch",
                "$toggle_view_binding_name": "touch_button_toggle",
                "ignored": "(not $touch_supported or $nx_os)",
                "$toggle_group_forced_index": "$touch_forced_index"
              }
            }
          ]
        }
      },
      {
        "general": {
          "type": "stack_panel",
          "size": ["100%", "100%c"],
          "controls": [
            {
              "general_group_name@xc_modern_settings:main_content.selector_group_label": {
                "$section_text": "stat.generalButton"
              }
            },
            {
              "general@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "general",
                "$button_text": "options.general",
                "$toggle_view_binding_name": "general_button_toggle",
                //"$toggle_group_forced_index": "$general_forced_index",
                "$toggle_group_forced_index": 102,
                "ignored": "(not $include_controls_and_settings_sections)"
              }
            },
            {
              "graphic@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "graphic",
                "$button_text": "options.video",
                "$toggle_view_binding_name": "graphic_button_toggle",
                //"$toggle_group_forced_index": "$video_forced_index",
                "$toggle_group_forced_index": 103,
                "ignored": "(not $include_controls_and_settings_sections)"
              }
            },
            {
              "sound@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "sounds",
                "$button_text": "options.sounds",
                "$toggle_view_binding_name": "sound_button_toggle",
                //"$toggle_group_forced_index": "$sound_forced_index",
                "$toggle_group_forced_index": 104,
                "ignored": "(not $include_controls_and_settings_sections)"
              }
            },
            {
              "global_resource_pack@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "resource_pack",
                "$button_text": "menu.globalpacks",
                "$toggle_view_binding_name": "global_resource_pack_button_toggle",
                //"$toggle_group_forced_index": "$global_texture_pack_forced_index",
                "$toggle_group_forced_index": 105,
                "ignored": "($ignore_global_resources_section and (not $include_controls_and_settings_sections))",
                "visible": "($is_global_texture_packs_visible)"
              }
            },
            {
              "language@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "language",
                "$button_text": "options.language",
                "$toggle_view_binding_name": "language_button_toggle",
                //"$toggle_group_forced_index": "$language_forced_index",
                "$toggle_group_forced_index": 106
              }
            },
            {
              "storage@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "storage",
                "$button_text": "menu.storageManagement",
                "$toggle_view_binding_name": "storage_management_button_toggle",
                //"$toggle_group_forced_index": "$storage_management_forced_index",
                "$toggle_group_forced_index": 107,
                "ignored": "($ignore_storage_section and (not $include_controls_and_settings_sections))",
                "visible": "$is_pregame"
              }
            },
            {
              "creator@xc_modern_settings:main_content.section_toggle_base": {
                "$button_icon": "creator",
                "$button_text": "options.creator",
                "$toggle_view_binding_name": "creator_button_toggle",
                //"$toggle_group_forced_index": "$creator_forced_index",
                "$toggle_group_forced_index": 108,
                "ignored": "($ignore_creator_section and (not $include_controls_and_settings_sections))"
              }
            }
          ]
        }
      }
    ]
  },
  "section_pages_main_content_base": {
    "type": "stack_panel",
    "$toggle_view_binding_name|default": "none",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$toggle_view_binding_name",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [0, 1],
    "visible": false
  },
  "section_pages_panel": {
    "type": "panel",
    "size": ["100%", "100%c + 2px"],
    "controls": [
      {
        "accessibility@xc_modern_settings:accessibility.main_content": {}
      },
      {
        "general@xc_modern_settings:general.main_content": {}
      },
      {
        "graphic@xc_modern_settings:graphic.main_content": {}
      },
      {
        "sound@xc_modern_settings:sound.main_content": {}
      },
      {
        "language@xc_modern_settings:language.main_content": {}
      },
      {
        "creator@xc_modern_settings:creator.main_content": {}
      }
    ]
  },
  "option_stack_panel": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": ["100%", "100%cm"]
  },
  "background": {
    "type": "panel",
    "controls": [
      {
        "in_game@xc_backgrounds.menu_background": {
          "ignored": "$is_pregame"
        }
      },
      {
        "not_in_game@xc_common.background_for_pregame_only": {}
      }
    ]
  },
  "main_content": {
    "type": "panel",
    "controls": [
      {
        "selector_background": {
          "type": "image",
          "texture": "textures/XeroxClient/rounded_corner/all8x",
          "color": "$xeroxclient_ui_theme_menu_background_color",
          "alpha": "$xeroxclient_ui_theme_menu_background_alpha",
          "size": ["100%c + 5px", "100% - 50px"],
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "offset": [25, 0],
          "controls": [
            {
              "scrolling_panel@xc_modern_scrolling_panel.scrolling_panel": {
                "size": [115, "100% - 5px"],
                "$scrolling_content": "xc_modern_settings:main_content.section_selector_panel"
              }
            }
          ]
        }
      },
      {
        "section_pages_background": {
          "type": "image",
          "texture": "textures/XeroxClient/rounded_corner/all8x",
          "color": "$xeroxclient_ui_theme_menu_background_color",
          "alpha": "$xeroxclient_ui_theme_menu_background_alpha",
          "size": ["100% - 185px", "100% - 50px"],
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "offset": [-25, 0],
          "controls": [
            {
              "scrolling_panel@xc_modern_scrolling_panel.scrolling_panel": {
                "size": ["100% - 5px", "100% - 5px"],
                "$scrolling_content": "xc_modern_settings:main_content.section_pages_panel"
              }
            },
            {
              "unchanged_section_panel": {
                "type": "panel",
                "size": ["100% - 10px", "100% - 5px"],
                "controls": [
                  {
                    "unchanged_section_label": {
                      "type": "label",
                      "text": "xc.options.unchangedSectionNotice",
                      "font_type": "$global_font_type",
                      "backup_font_type": "$global_font_type_backup",
                      "size": ["100%", "default"],
                      "text_alignment": "center",
                      "anchor_from": "top_middle",
                      "anchor_to": "top_middle"
                    }
                  }
                ],
                "bindings": [
                  {
                    "binding_type": "view",
                    "source_control_name": "touch_button_toggle",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#condition0"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "controller_button_toggle",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#condition1"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "keyboard_and_mouse_button_toggle",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#condition2"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "storage_management_button_toggle",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#condition3"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "game_button_toggle",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#condition3"
                  },
                  {
                    "binding_type": "view",
                    "source_control_name": "multiplayer_button_toggle",
                    "source_property_name": "#toggle_state",
                    "target_property_name": "#condition3"
                  },
                  {
                    "binding_type": "view",
                    "source_property_name": "(#condition0 or #condition1 or #condition2 or #condition3)",
                    "target_property_name": "#visible"
                  }
                ]
              }
            },
            {
              "global_resource_pack@xc_modern_settings:global_resource_packs.main_content": {
                "size": ["100% - 10px", "100% - 5px"]
              }
            }
          ]
        }
      },
      {
        "close_button": {
          "type": "input_panel",
          "size": ["100%", 25],
          "anchor_from": "bottom_middle",
          "anchor_to": "bottom_middle",
          "propagate_alpha": true,
          "anims": [
            "@settings_animation.close_button_area_description_fade1",
            "@settings_animation.close_button_area_description_fade2"
          ],
          "layer": 1,
          "controls": [
            {
              "diffussion": {
                "type": "image",
                "texture": "textures/XeroxClient/diffusion",
                "color": "$xeroxclient_ui_theme_menu_background_color",
                "alpha": "$xeroxclient_ui_theme_menu_background_alpha",
                "size": ["100%sm + 150px", "250%"],
                "max_size": ["100%", "250%"],
                "anchor_from": "bottom_middle",
                "anchor_to": "center",
                "layer": 2
              }
            },
            {
              "text": {
                "type": "label",
                "text": "xc.options.closeButtonAreaDescription",
                "size": ["default", "default"],
                "font_type": "$global_font_type",
                "backup_font_type": "$global_font_type_backup",
                "layer": 3
              }
            }
          ],
          "button_mappings": [
            {
              "from_button_id": "button.menu_select",
              "to_button_id": "button.menu_exit",
              "mapping_type": "double_pressed"
            }
          ]
        }
      }
    ]
  }
}
