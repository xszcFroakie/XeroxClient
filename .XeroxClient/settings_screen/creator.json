                    "binding_name": "#content_log_location_text",
                    "binding_name_override": "#text"
                  },
                  {
                    "binding_name": "#content_log_file_enabled",
                    "binding_name_override": "#visible"
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  }
}
