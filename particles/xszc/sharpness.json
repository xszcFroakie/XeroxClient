{
  // Inspired by Java 1.7 Animation

  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "xszc:sharpness_particle",
      "basic_render_parameters": {
        "material": "particles_alpha",
        "texture": "textures/particle/particles"
      }
    },
    "components": {
      "minecraft:emitter_local_space": {
        "position": false,
        "rotation": false,
        "velocity": true
      },
      "minecraft:emitter_rate_instant": { "num_particles": 20 },
      "minecraft:emitter_lifetime_once": { "active_time": 0 },
      "minecraft:particle_initial_speed": "Math.random(6, 14)",
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "6 / (Math.random(0, 16) + 12)"
      },
      "minecraft:emitter_shape_point": {
        "offset": [0, 0, 0],
        "direction": [
          "Math.random(-1, 1)",
          "Math.random(-1, 1)",
          "Math.random(-1, 1)"
        ]
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [0, -5, 0],
        "linear_drag_coefficient": 10
      },
      "minecraft:particle_appearance_billboard": {
        "size": [
          "0.08 + v.particle_random_1 * 0.02",
          "0.08 + v.particle_random_1 * 0.02"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [16, 32],
          "uv_size": [8, 8]
        }
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_appearance_tinting": {
        "color": {
          "gradient": [
            [
              "(v.particle_random_1 * 0.3 + 0.6) * 0.3",
              "(v.particle_random_2 * 0.3 + 0.6) * 0.8",
              "v.particle_random_2 * 0.3 + 0.6",
              1.0
            ],
            ["(v.particle_random_1 * 0.3 + 0.6) * 0.3", 0.4, 0.3, 1.0]
          ],
          "interpolant": "v.particle_age/v.particle_lifetime"
        }
      }
    }
  }
}
